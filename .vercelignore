# Vercel upload ignore — only ship apps/web + packages/* to Vercel

# Dependencies / build output
node_modules
**/node_modules
.next
**/.next
dist
**/dist
coverage
**/coverage

# Local env / logs
.env
.env.local
.env.*.local
*.log

# Tooling / local metadata
.git
.github
.husky
.vscode
.idea
.vercel
.windsurf
.windsurfrules
.agents

# Test & format config (not needed at runtime)
.prettierrc.json
.prettierignore
commitlint.config.mjs
**/vitest.config.ts
**/vitest.setup.ts
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs
docs/
*.md
