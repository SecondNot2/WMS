# =============================================================================
# Docker Compose env file — copy to .env.docker and fill in secrets.
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up -d
# =============================================================================

# ── Postgres credentials (used by both `postgres` and `web` services) ──
POSTGRES_DB=wms
POSTGRES_USER=wms
POSTGRES_PASSWORD=wms_dev_password
POSTGRES_PORT=5432

# ── Web service ──
WEB_PORT=3000

# ── JWT secrets — REQUIRED. Generate with:
#      openssl rand -base64 64
JWT_SECRET=replace-with-strong-random-string-min-64-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-string-min-64-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Logger ──
LOG_LEVEL=info

# ── Supabase (optional — leave blank to disable storage + realtime) ──
# Realtime stock updates and image uploads will no-op when blank.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REALTIME_CHANNEL=wms
