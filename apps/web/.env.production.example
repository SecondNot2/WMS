# =====================================================
# WMS Web — Production Environment Variables (Vercel)
# =====================================================
# Backend đã merge vào Next.js Route Handlers — không cần deploy server riêng.
# Copy các biến này vào: Vercel Dashboard → Project → Settings → Environment Variables
# Scope: Production + Preview (Development optional)

# ── Database (Supabase Postgres) — BẮT BUỘC ──
# Pooled (port 6543, pgbouncer) cho runtime serverless
DATABASE_URL=""
# Direct (port 5432) cho `prisma migrate deploy`
DIRECT_URL=""

# ── JWT — BẮT BUỘC đặt strong random secrets (>= 32 chars) ──
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── Supabase Storage (upload ảnh client-side) — BẮT BUỘC ──
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Supabase Realtime broadcast (server emit events) — TUỲ CHỌN ──
# Nếu không set → emit sẽ no-op, frontend dùng TanStack Query invalidate là đủ
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_REALTIME_CHANNEL="wms"

# ── Logger ──
LOG_LEVEL="info"

# ── API URL — KHÔNG cần set, mặc định '/api' cùng domain ──
# NEXT_PUBLIC_API_URL=""
