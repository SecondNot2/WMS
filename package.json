{
  "name": "wms",
  "version": "0.1.0",
  "private": true,
  "description": "Warehouse Management System monorepo (web + api)",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @wms/web dev",
    "dev:api": "pnpm --filter @wms/api dev",
    "build": "pnpm --recursive build",
    "build:web": "pnpm --filter @wms/web build",
    "build:api": "pnpm --filter @wms/api build",
    "type-check": "pnpm --recursive type-check",
    "lint": "pnpm --recursive lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
