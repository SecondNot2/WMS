# =====================================================
# WMS Web — Local Development (.env)
# =====================================================
# Lưu ý: backend đã được merge vào Next.js Route Handlers.
# Chỉ cần file này, KHÔNG còn .env riêng cho apps/api.

# ── API URL (mặc định '/api' cùng domain — chỉ override nếu gọi backend riêng) ──
# NEXT_PUBLIC_API_URL="/api"

# ── Database (Supabase Postgres) ──
# Pooled connection cho runtime (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection cho migrations (port 5432)
DIRECT_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ── JWT (BẮT BUỘC đặt strong secret cho production) ──
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── Logger ──
LOG_LEVEL="debug"

# ── Supabase Storage (upload ảnh sản phẩm/avatar — client-side) ──
# Tạo bucket public `wms-uploads` trong Supabase Dashboard → Storage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Supabase Realtime broadcast (server-side emit stock/inbound/outbound events) ──
# Bỏ trống ở local → emit sẽ là no-op (không lỗi)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_REALTIME_CHANNEL="wms"
